<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Agents Showcase</title>
<style>
/* Pure Local Fonts & Tailwind-equivalent styles embedded - No external CDNs */
body{font-family:'Courier New',monospace,Courier,monospace !important;background:#0a0a0a;color:#e2e8f0}
:root{
  --bg:#07070e;--s1:#0d0d1a;--s2:#111120;
  --b1:#1c1c30;--b2:#252540;
  --t1:#e2e8f0;--t2:#94a3b8;--t3:#475569;
  --g:#00ff88;--r:#f43f5e;--b:#3b82f6;--p:#8b5cf6;--q:#00ffff;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden}
body{font-family:'JetBrains Mono',monospace;background:#0a0a0a;color:var(--t1);display:flex;flex-direction:column;margin:0;overflow:hidden}

/* MATRIX BG */
#mbg{position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;opacity:.03;pointer-events:none}

.layout{display:flex;flex:1;overflow:hidden;position:relative;z-index:1}

/* SIDEBAR */
.sb{width:220px;background:rgba(0,255,136,.02);border-right:1px solid rgba(0,255,136,.1);display:flex;flex-direction:column;overflow-y:auto;flex-shrink:0}
.sb-logo{padding:12px;border-bottom:1px solid rgba(0,255,136,.1);display:flex;align-items:center;gap:8px}
.sb-gem{width:28px;height:28px;border-radius:7px;background:linear-gradient(135deg,#00ff88,#00ccff);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;color:#000;flex-shrink:0}
.sb-title{font-size:10px;font-weight:700;color:var(--g)}
.sb-sec{padding:8px 10px 3px;font-size:7px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:rgba(0,255,136,.35)}
.ni{display:flex;align-items:center;gap:6px;padding:6px 10px;cursor:pointer;font-size:9px;color:rgba(0,255,136,.5);border-radius:0 12px 12px 0;margin-right:6px;transition:all .15s}
.ni:hover{background:rgba(0,255,136,.07);color:var(--g)}
.ni.on{background:rgba(0,255,136,.12);color:var(--g);border-left:2px solid var(--g)}
.nb{margin-left:auto;font-size:7px;padding:1px 4px;border-radius:999px}

/* MAIN */
.main{flex:1;display:flex;flex-direction:column;overflow:hidden}
.header{padding:0 14px;height:46px;border-bottom:1px solid rgba(0,255,136,.1);display:flex;align-items:center;gap:8px;flex-shrink:0;background:rgba(0,255,136,.02)}
.hbtn{padding:5px 12px;border-radius:8px;font-size:9px;font-weight:700;cursor:pointer;border:1px solid;transition:all .2s}
.hbtn-g{background:rgba(0,255,136,.12);border-color:rgba(0,255,136,.3);color:var(--g)}
.hbtn-g:hover{background:rgba(0,255,136,.22);box-shadow:0 0 12px rgba(0,255,136,.3)}
.hbtn-r{background:rgba(244,63,94,.12);border-color:rgba(244,63,94,.3);color:var(--r)}
.hbtn-r:disabled{opacity:.4;cursor:not-allowed}

/* TABS */
.tabs{display:flex;border-bottom:1px solid rgba(0,255,136,.1);overflow-x:auto;flex-shrink:0}
.tabs::-webkit-scrollbar{height:0}
.tab{padding:7px 12px;font-size:9px;font-weight:600;color:rgba(0,255,136,.35);cursor:pointer;border:none;background:transparent;border-bottom:2px solid transparent;transition:all .15s;white-space:nowrap}
.tab:hover{color:rgba(0,255,136,.7)}
.tab.on{color:var(--g);border-bottom-color:var(--g)}

/* CONTENT */
.content{flex:1;overflow-y:auto;padding:14px}
::-webkit-scrollbar{width:3px}
::-webkit-scrollbar-thumb{background:rgba(0,255,136,.2)}

/* CARDS */
.card{background:rgba(0,255,136,.03);border:1px solid rgba(0,255,136,.1);border-radius:10px;padding:12px;transition:border-color .2s}
.card-r{border-left:2px solid var(--r)}
.card-g{border-left:2px solid var(--g)}
.card-b{border-left:2px solid var(--b)}
.card-q{border-left:2px solid var(--q)}

/* TERMINAL */
.term{background:#010106;border:1px solid rgba(0,255,136,.15);border-radius:8px;padding:10px;overflow-y:auto;font-size:10px;line-height:1.8;color:var(--g)}
.tl{display:block}
.tok{color:var(--g)}.ti{color:#06b6d4}.tw{color:#eab308}.te{color:var(--r)}.tq{color:var(--q)}
.tp{color:var(--b)}

/* AGENT CARDS */
.ac{background:rgba(0,255,136,.03);border:1px solid rgba(0,255,136,.1);border-radius:9px;padding:10px;transition:all .2s}
.ac:hover{border-color:rgba(0,255,136,.3)}
.ac.deployed{border-color:rgba(0,255,136,.5);background:rgba(0,255,136,.07)}
.ac.deploying{border-color:var(--q);animation:qPulse 1s infinite}
.ac.error{border-color:var(--r)}
@keyframes qPulse{0%,100%{box-shadow:0 0 6px rgba(0,255,255,.1)}50%{box-shadow:0 0 16px rgba(0,255,255,.4)}}

/* PROGRESS */
.pbar{height:3px;border-radius:999px;background:rgba(0,255,136,.08);overflow:hidden}
.pf{height:100%;border-radius:999px;transition:width .5s ease}

/* CHIP */
.chip{display:inline-flex;align-items:center;gap:3px;padding:2px 6px;border-radius:999px;font-size:7px;font-weight:700}
.ch-g{background:rgba(0,255,136,.12);color:var(--g);border:1px solid rgba(0,255,136,.25)}
.ch-r{background:rgba(244,63,94,.12);color:var(--r);border:1px solid rgba(244,63,94,.25)}
.ch-b{background:rgba(59,130,246,.12);color:var(--b);border:1px solid rgba(59,130,246,.25)}
.ch-q{background:rgba(0,255,255,.12);color:var(--q);border:1px solid rgba(0,255,255,.25)}
.ch-y{background:rgba(234,179,8,.12);color:#eab308;border:1px solid rgba(234,179,8,.25)}

/* STATUS */
.dot{width:5px;height:5px;border-radius:50%;display:inline-block}
.dg{background:var(--g);animation:dp 2s infinite}
.dr{background:var(--r);animation:dp 1.5s infinite}
.dy{background:#eab308;animation:dp 2.5s infinite}
@keyframes dp{0%,100%{opacity:1}50%{opacity:.3}}

/* FILE LIST */
.fitem{display:flex;align-items:center;gap:7px;padding:4px 6px;border-radius:5px;font-size:9px;transition:background .15s}
.fitem.done{color:var(--g)}
.fitem.active{color:var(--q);background:rgba(0,255,255,.04)}
.fitem.pending{color:rgba(0,255,136,.35)}
.fitem.error{color:var(--r)}
.fi-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.fi-dot.done{background:var(--g)}
.fi-dot.active{background:var(--q);animation:dp 1s infinite}
.fi-dot.pending{background:rgba(0,255,136,.2)}
.fi-dot.error{background:var(--r)}

/* SECURITY ALERT */
.sec-alert{background:rgba(244,63,94,.08);border:1px solid rgba(244,63,94,.3);border-radius:10px;padding:14px;margin-bottom:14px}
.sa-title{font-size:11px;font-weight:700;color:var(--r);margin-bottom:6px;display:flex;align-items:center;gap:6px}
.sa-step{display:flex;align-items:start;gap:8px;margin-bottom:6px;font-size:9px;color:var(--t2)}
.sa-num{width:16px;height:16px;border-radius:50%;background:rgba(244,63,94,.2);border:1px solid rgba(244,63,94,.3);color:var(--r);display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:700;flex-shrink:0}

/* ANIMATIONS */
@keyframes fadeUp{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:translateY(0)}}
@keyframes spin{to{transform:rotate(360deg)}}
.fa{animation:fadeUp .25s ease forwards}
.spinning{animation:spin 1s linear infinite;display:inline-block}

/* GLOBAL PROGRESS */
.gp{background:rgba(0,255,136,.04);border:1px solid rgba(0,255,136,.12);border-radius:10px;padding:12px;margin-bottom:12px}
.gp-bar{height:6px;border-radius:999px;background:rgba(0,255,136,.08);overflow:hidden;margin:8px 0}
.gp-fill{height:100%;border-radius:999px;background:linear-gradient(90deg,var(--g),var(--q));transition:width .4s ease}

@media(max-width:768px){.sb{display:none}.main{width:100%}}

/* GEMINI WAVE INTERFACE */
:root {
  --gemini-blue: #4488FF;
  --electric-violet: #A855F7;
  --glass-bg: rgba(255, 255, 255, 0.04);
  --glass-border: rgba(255, 255, 255, 0.08);
  --glass-blur: blur(40px);
}

.gemini-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  position: relative;
  padding: 20px;
  box-sizing: border-box;
}

.ghost-status {
  font-size: 0.8rem;
  letter-spacing: 2px;
  opacity: 0.6;
  margin-bottom: 20px;
  color: var(--g);
  text-transform: uppercase;
  font-weight: 500;
}

.wave-wrapper {
  width: 100%;
  max-width: 800px;
  filter: blur(8px);
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: -1;
  pointer-events: none;
}

.waves {
  width: 100%;
  height: 100%;
}

.parallax > use {
  animation: move-forever 25s cubic-bezier(.55,.5,.45,.5) infinite;
}

.parallax > use:nth-child(1) { animation-delay: -2s; animation-duration: 7s; }
.parallax > use:nth-child(2) { animation-delay: -3s; animation-duration: 10s; }
.parallax > use:nth-child(3) { animation-delay: -4s; animation-duration: 13s; }
.parallax > use:nth-child(4) { animation-delay: -5s; animation-duration: 20s; }

@keyframes move-forever {
  0% { transform: translate3d(-90px,0,0); }
  100% { transform: translate3d(85px,0,0); }
}

/* CINEMATIC SLIDESHOW */
.slideshow-section {
  width: 100%;
  max-width: 1000px;
  margin-bottom: 50px;
}

.slideshow-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20px;
  position: relative;
}

.focus-card {
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 1px solid var(--glass-border);
  padding: 40px;
  border-radius: 24px;
  width: 100%;
  max-width: 600px;
  text-align: center;
  position: relative;
  z-index: 10;
  transition: all 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.focus-card.transitioning {
  transform: scale(0.95);
  opacity: 0.3;
}

.focus-card h2 {
  color: var(--gemini-blue);
  font-size: 2.5rem;
  margin-bottom: 10px;
  font-weight: 700;
}

.focus-card p {
  margin: 8px 0;
  font-size: 1rem;
  opacity: 0.9;
}

.capabilities-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 10px;
  margin: 20px 0;
}

.capability-item {
  background: rgba(255, 255, 255, 0.1);
  padding: 8px 16px;
  border-radius: 20px;
  font-size: 0.8rem;
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.live-logic-feed {
  background: rgba(0, 0, 0, 0.8);
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: 8px;
  padding: 15px;
  margin-top: 20px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.9rem;
  min-height: 60px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.live-logic-feed .cursor {
  animation: blink 1s infinite;
}

@keyframes blink {
  0%, 50% { opacity: 1; }
  51%, 100% { opacity: 0; }
}

.nav-btn {
  background: none;
  border: none;
  color: white;
  font-size: 3rem;
  cursor: pointer;
  padding: 20px;
  transition: all 0.3s ease;
  z-index: 20;
  position: relative;
}

.nav-btn:hover {
  color: var(--gemini-blue);
  transform: scale(1.1);
}

.slide-indicators {
  display: flex;
  justify-content: center;
  gap: 10px;
  margin-top: 20px;
}

.indicator {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  cursor: pointer;
  transition: all 0.3s ease;
}

.indicator.active {
  background: var(--gemini-blue);
  transform: scale(1.5);
}

/* FLM TEMPLATE GENERATOR */
.generator-section {
  width: 100%;
  max-width: 800px;
  text-align: center;
  margin-bottom: 30px;
}

.section-title {
  font-size: 2rem;
  color: var(--gemini-blue);
  margin-bottom: 10px;
  font-weight: 700;
}

.section-subtitle {
  font-size: 1.1rem;
  opacity: 0.8;
  margin-bottom: 30px;
}

.command-center {
  display: flex;
  gap: 15px;
  margin-bottom: 30px;
  justify-content: center;
  flex-wrap: wrap;
}

#userCommand {
  background: rgba(0, 0, 0, 0.6);
  border: 2px solid var(--gemini-blue);
  padding: 15px 20px;
  width: 100%;
  max-width: 500px;
  color: white;
  border-radius: 12px;
  font-size: 1rem;
  outline: none;
  transition: all 0.3s ease;
  font-family: 'JetBrains Mono', monospace;
}

#userCommand:focus {
  border-color: var(--electric-violet);
  box-shadow: 0 0 20px rgba(68, 136, 255, 0.3);
}

#generateBtn {
  background: linear-gradient(135deg, var(--gemini-blue), var(--electric-violet));
  border: none;
  padding: 15px 30px;
  color: white;
  border-radius: 12px;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

#generateBtn:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 25px rgba(68, 136, 255, 0.4);
}

#generateBtn.loading {
  pointer-events: none;
}

#generateBtn::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  transform: translate(-50%, -50%);
  transition: width 0.6s, height 0.6s;
}

#generateBtn:active::before {
  width: 300px;
  height: 300px;
}

.output-box {
  background: rgba(0, 0, 0, 0.9);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 12px;
  padding: 20px;
  width: 100%;
  max-width: 800px;
  animation: slideUp 0.5s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(30px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.output-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15px;
  padding-bottom: 10px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

#output-filename {
  color: var(--gemini-blue);
  font-family: 'JetBrains Mono', monospace;
}

.copy-btn {
  background: var(--gemini-blue);
  border: none;
  padding: 8px 16px;
  border-radius: 6px;
  color: white;
  cursor: pointer;
  font-size: 0.9rem;
  transition: all 0.3s ease;
}

.copy-btn:hover {
  background: var(--electric-violet);
}

#code-content {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.9rem;
  line-height: 1.5;
  color: #e0e0e0;
  white-space: pre-wrap;
  word-wrap: break-word;
}

/* STATUS BAR */
.status-bar {
  display: flex;
  justify-content: center;
  gap: 20px;
  flex-wrap: wrap;
  margin-top: 30px;
  padding: 20px;
  background: rgba(10, 10, 10, 0.8);
  border-radius: 12px;
  border: 1px solid rgba(0, 100, 255, 0.2);
}

.status-item {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.85rem;
  opacity: 0.9;
  color: #e0e0e0;
}

.status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #ff4757;
  box-shadow: 0 0 4px rgba(255, 71, 87, 0.5);
}

.status-dot.active {
  background: #2ed573;
  box-shadow: 0 0 8px rgba(46, 213, 115, 0.6);
  animation: pulse-dot 2s infinite;
}

@keyframes pulse-dot {
  0%, 100% {
    opacity: 1;
    box-shadow: 0 0 8px rgba(46, 213, 115, 0.6);
  }
  50% {
    opacity: 0.7;
    box-shadow: 0 0 12px rgba(46, 213, 115, 0.9);
  }
}

/* RESPONSIVE DESIGN */
/* SOVEREIGN ADMIN PORTAL */
.admin-portal {
  margin-top: 100px;
  padding: 40px;
  background: rgba(10, 10, 10, 0.85);
  border-top: 2px solid var(--gemini-blue);
  border-bottom: 2px solid var(--gemini-blue);
  backdrop-filter: blur(20px);
  width: 100%;
  max-width: 1200px;
  border-radius: 12px;
  box-shadow: 0 0 60px rgba(0, 100, 255, 0.08);
}

.admin-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 0.7rem;
  letter-spacing: 3px;
  color: var(--gemini-blue);
  margin-bottom: 30px;
  padding-bottom: 15px;
  border-bottom: 1px solid rgba(0, 100, 255, 0.15);
}

.portal-title {
  font-weight: bold;
  font-size: 0.8rem;
}

.status-badge {
  background: rgba(0, 100, 255, 0.1);
  padding: 5px 15px;
  border-radius: 20px;
  border: 1px solid rgba(0, 100, 255, 0.3);
  animation: pulse-glow 2s ease-in-out infinite;
}

@keyframes pulse-glow {
  0%, 100% { box-shadow: 0 0 5px rgba(0, 100, 255, 0.2); }
  50% { box-shadow: 0 0 15px rgba(0, 100, 255, 0.5); }
}

.training-grid {
  display: flex;
  gap: 30px;
}

.input-group {
  flex: 2;
}

.input-group label {
  display: block;
  font-size: 0.65rem;
  letter-spacing: 2px;
  color: #555;
  margin-bottom: 10px;
  text-transform: uppercase;
}

.admin-portal textarea {
  width: 100%;
  height: 140px;
  background: #000;
  border: 1px solid #222;
  color: #00ff88;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.85rem;
  padding: 18px;
  border-radius: 8px;
  resize: vertical;
  transition: border-color 0.3s;
}

.admin-portal textarea:focus {
  outline: none;
  border-color: var(--gemini-blue);
  box-shadow: 0 0 20px rgba(0, 100, 255, 0.1);
}

.control-panel {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.btn-pro {
  background: var(--gemini-blue);
  color: white;
  border: none;
  padding: 16px;
  border-radius: 6px;
  font-weight: bold;
  font-size: 0.75rem;
  letter-spacing: 1px;
  cursor: pointer;
  transition: all 0.3s;
}

.btn-pro:hover {
  background: #0077ff;
  box-shadow: 0 0 25px rgba(0, 100, 255, 0.4);
}

.btn-secure {
  background: rgba(0, 255, 136, 0.1);
  color: #00ff88;
  border: 1px solid rgba(0, 255, 136, 0.3);
  padding: 12px;
  border-radius: 6px;
  font-size: 0.7rem;
  letter-spacing: 1px;
  cursor: pointer;
  transition: all 0.3s;
}

.btn-secure:hover {
  background: rgba(0, 255, 136, 0.2);
  box-shadow: 0 0 20px rgba(0, 255, 136, 0.2);
}

.btn-warn {
  background: rgba(255, 50, 50, 0.1);
  color: #ff4444;
  border: 1px solid rgba(255, 50, 50, 0.3);
  padding: 12px;
  border-radius: 6px;
  font-size: 0.7rem;
  letter-spacing: 1px;
  cursor: pointer;
  transition: all 0.3s;
}

.btn-warn:hover {
  background: rgba(255, 50, 50, 0.2);
}

.live-stats {
  font-size: 0.65rem;
  color: #555;
  margin-top: 15px;
  line-height: 2;
  padding: 15px;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 6px;
  border: 1px solid #111;
}

.monitor-bar {
  display: flex;
  justify-content: space-between;
  margin-top: 30px;
  padding-top: 20px;
  border-top: 1px solid rgba(0, 100, 255, 0.1);
  font-size: 0.6rem;
  letter-spacing: 1px;
  color: #444;
}

.mev-counter {
  color: #00ff88;
}

@media (max-width: 768px) {
  .focus-card {
    padding: 25px;
    max-width: 90vw;
  }

  .focus-card h2 {
    font-size: 2rem;
  }

  .nav-btn {
    font-size: 2rem;
    padding: 15px;
  }

  .command-center {
    flex-direction: column;
    align-items: center;
  }

  #userCommand {
    max-width: 100%;
  }

  .status-bar {
    gap: 15px;
  }

  .capabilities-list {
    flex-direction: column;
    align-items: center;
  }

  .training-grid {
    flex-direction: column;
  }

  .admin-portal {
    padding: 20px;
    margin-top: 50px;
  }

  .admin-header {
    flex-direction: column;
    gap: 10px;
    text-align: center;
  }
}
</style>
</head>
<body>

<canvas id="mbg"></canvas>

<div class="layout">

<!-- SIDEBAR -->
<aside class="sb">
    <div class="sb-logo">
    <div class="sb-gem">AI</div>
