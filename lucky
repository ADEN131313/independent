function cLog(type, msg) {
  const term = document.getElementById('deploy-console');
  if(!term) return;
  const cls = {ok:'tok', info:'ti', warn:'tw', err:'te', q:'tq'}[type] || 'ti';
  const s   = document.createElement('span');
  s.className = 'tl';
  s.innerHTML = `<span class="${cls}">${msg}</span>`;
  const cur = document.getElementById('console-cursor')?.closest('.tl');
  if(cur) term.insertBefore(s, cur);
  else term.appendChild(s);
  term.scrollTop = term.scrollHeight;
}

function updateGP(done, total, label) {
  const gp = document.getElementById('global-progress');
  if(gp) gp.style.display = 'block';
  const pct = total ? Math.round(done/total*100) : 0;
  const fill = document.getElementById('gp-fill');
  const badge = document.getElementById('gp-badge');
  const cur   = document.getElementById('gp-current');
  const title = document.getElementById('gp-title');
  if(fill)  fill.style.width  = pct + '%';
  if(badge) badge.textContent = `${done} / ${total} files`;
  if(cur)   cur.textContent   = label || '';
  if(title) title.textContent = done === total && total > 0 ? '✅ Deployment Complete' : '⚡ Deploying...';
  // Sidebar bar
  const sbar = document.getElementById('sb-bar');
  const sst  = document.getElementById('sb-status');
  if(sbar) sbar.style.width = pct + '%';
  if(sst)  sst.textContent  = `${pct}% · ${done}/${total}`;
}

function updateAgentCard(agentId, fileIdx, status, pct) {
  const a = AGENTS.find(x => x.id === agentId);
  if(!a) return;
  const card  = document.getElementById(`ac-${agentId}`);
  const bar   = document.getElementById(`ac-bar-${agentId}`);
  const badge = document.getElementById(`ac-badge-${agentId}`);
  if(card) {
    card.className = `ac ${status === 'done' ? 'deployed' : status === 'deploying' ? 'deploying' : status === 'error' ? 'error' : ''}`;
  }
  if(bar && pct !== undefined) bar.style.width = pct + '%';
  if(badge) {
    badge.textContent  = status === 'done' ? '✅ Done' : status === 'deploying' ? '⟳ Deploying' : status === 'error' ? '❌ Error' : 'Pending';
    badge.className    = `chip ${status==='done'?'ch-g':status==='deploying'?'ch-q':status==='error'?'ch-r':'ch-b'} `;
  }
  // Update sidebar agent status
  const sbSt = document.getElementById(`sb-a-st-${agentId}`);
  if(sbSt) sbSt.style.color = status === 'done' ? 'var(--g)' : status === 'deploying' ? 'var(--q)' : 'var(--r)';

  // File items
  const filesEl = document.getElementById(`ac-files-${agentId}`);
  if(filesEl && fileIdx >= 0) {
    const items = filesEl.querySelectorAll('.fitem');
    if(items[fileIdx]) {
      items[fileIdx].className = `fitem ${status === 'done' ? 'done' : status === 'deploying' ? 'active' : 'error'}`;
      const dot = items[fileIdx].querySelector('.fi-dot');
      if(dot) dot.className = `fi-dot ${status === 'done' ? 'done' : status === 'deploying' ? 'active' : 'error'}`;
    }
  }
}

