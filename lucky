        strategy = self._adopt(signals)
        compiled = self._compile(strategy)
        implanted= await self._implant(compiled)
        self._verify()

        elapsed = (time.monotonic() - t0) * 1000
        result  = CycleResult(
            cycle=self._cycle,
            elapsed_ms=round(elapsed, 2),
            signals=signals,
            implanted=implanted,
        )
        self._history.append(result)
        self._cycle += 1

        print(
            f"[${agent.flm}] cycle={self._cycle - 1:06d} "
            f"sig={len(signals)} impl={implanted} "
            f"ms={elapsed:.1f} sig={result.sign()}"
        )
        return result

    async def run(self) -> None:
        """Run continuously — 1-second cycle forever."""
        self._running = True
        while self._running:
            t0 = time.monotonic()
            await self.adopt_implant_cycle()
            sleep = max(0.0, 1.0 - (time.monotonic() - t0))
            await asyncio.sleep(sleep)

    def stop(self) -> None:
        self._running = False

    # ── Layer Implementations ──────────────────────

    async def _scan(self) -> list[dict]:
        """SCAN: Detect optimization signals."""
        await asyncio.sleep(0)
        return [{"signal": "cycle_scan", "agent": "${agent.id}", "ts": time.time()}]

    def _adopt(self, signals: list[dict]) -> dict:
        """ADOPT: Extract highest-value strategy."""
        if not signals:
            return {}
        return {"strategy": signals[0], "cycle": self._cycle}

    def _compile(self, strategy: dict) -> bytes:
        """COMPILE: Run through ${agent.model} proprietary compiler."""
        if not strategy:
            return b""
        return hashlib.sha3_256(
            json.dumps(strategy, sort_keys=True).encode()
        ).digest()

    async def _implant(self, compiled: bytes) -> int:
        """IMPLANT: Inject compiled delta into core architecture."""
        await asyncio.sleep(0)
        return 1 if compiled else 0

    def _verify(self) -> None:
        """VERIFY: Core Memory Partition — True North preserved."""
        assert self.TRUE_NORTH.owner   == "poolvoid.eth", "OWNER CORRUPTED"
        assert self.TRUE_NORTH.ceiling is None,            "CEILING IMPOSED"
        assert self.FLM_ID == "${agent.flm}-356O",         "FLM_ID CORRUPTED"

    # ── Properties ────────────────────────────────

    @property
    def cycle(self) -> int:
        return self._cycle

    @property
    def history(self) -> list[CycleResult]:
        return self._history.copy()

    def __repr__(self) -> str:
        return (
            f"${agent.n.replace(' ','_')}FLM("
            f"engine={self.ENGINE!r}, "
            f"cycle={self._cycle}, "
            f"running={self._running})"
        )


if __name__ == "__main__":
