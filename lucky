function goTab(tabId, btn) {
  // Remove 'on' class from all tabs
  document.querySelectorAll('.tab').forEach(tab => tab.classList.remove('on'));

  // Add 'on' class to clicked tab
  if (btn) btn.classList.add('on');

  // Load content based on tab
  const content = document.getElementById('content');
  if (content) {
    if (tabId === 'agents') {
      content.innerHTML = rAgents();
      // Initialize slideshow after content is loaded
      setTimeout(() => {
        initializeSlideshow();
      }, 100);
    } else {
      content.innerHTML = `<div style="padding:20px;text-align:center;">Tab "${tabId}" content not implemented yet.</div>`;
    }
  }
}

// Legacy go function for sidebar
function go(section, el) {
  // Handle sidebar navigation
  document.querySelectorAll('.ni').forEach(item => item.classList.remove('on'));
  if (el) el.classList.add('on');

  // Go to agents tab
  if (section === 'deploy') {
    goTab('agents', document.getElementById('t-agents'));
  }
}

