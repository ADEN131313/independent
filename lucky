// ══════════════════════════════════════════════
// CINEMATIC SLIDESHOW SYSTEM
// ══════════════════════════════════════════════
let currentAgentIndex = 0;

function initializeSlideshow() {
  updateFocus();
  generateIndicators();
  startLiveFeed();
}

function updateFocus() {
  const agent = AGENTS[currentAgentIndex];
  const display = document.getElementById('agent-focus-display');

  if (!display) return;

  // Update wave color
  updateWaveColor(agent.accentColor);

  // Add transition class
  display.classList.add('transitioning');

  setTimeout(() => {
    display.innerHTML = `
      <h2 style="color: ${agent.accentColor}">${agent.n}</h2>
      <p><strong>Framework:</strong> ${agent.flm}</p>
      <p style="opacity:0.8; font-size: 0.9rem;">${agent.role}</p>
      <div class="capabilities-list">
        ${agent.capabilities.map(cap => `<div class="capability-item">${cap}</div>`).join('')}
      </div>
      <div class="live-logic-feed">
        <span id="live-feed-content">${agent.liveFeedSeed.split('\n')[0]}</span><span class="cursor">█</span>
      </div>
    `;

    display.classList.remove('transitioning');
  }, 300);

  updateIndicators();
}

function startLiveFeed() {
  let feedIndex = 0;

  setInterval(() => {
    const feedElement = document.getElementById('live-feed-content');
    if (feedElement && AGENTS.length > 0) {
      const currentAgent = AGENTS[feedIndex % AGENTS.length];
      const displayText = currentAgent.liveFeedSeed.split('\n')[0];
      feedElement.textContent = displayText;

      feedIndex++;
    }
  }, 3000);
}

function moveSlide(n) {
  const display = document.getElementById('agent-focus-display');
  if (display) display.classList.add('transitioning');

  setTimeout(() => {
    currentAgentIndex = (currentAgentIndex + n + AGENTS.length) % AGENTS.length;
    updateFocus();
  }, 300);
}

function generateIndicators() {
  const indicators = document.getElementById('slide-indicators');
  if (!indicators) return;

  indicators.innerHTML = AGENTS.map((_, index) =>
    `<div class="indicator ${index === currentAgentIndex ? 'active' : ''}" onclick="jumpToSlide(${index})"></div>`
  ).join('');
}

function updateIndicators() {
  const indicators = document.querySelectorAll('.indicator');
  indicators.forEach((indicator, index) => {
    indicator.classList.toggle('active', index === currentAgentIndex);
  });
}

function jumpToSlide(index) {
  if (index !== currentAgentIndex) {
    moveSlide(index - currentAgentIndex);
  }
}

// Keyboard navigation
document.addEventListener('keydown', (e) => {
  if (e.key === 'ArrowLeft') {
    moveSlide(-1);
  } else if (e.key === 'ArrowRight') {
    moveSlide(1);
  }
});

// Touch navigation
let startX = 0;
let endX = 0;

document.addEventListener('touchstart', (e) => {
  startX = e.touches[0].clientX;
});

document.addEventListener('touchend', (e) => {
  endX = e.changedTouches[0].clientX;
  const diff = startX - endX;

  if (Math.abs(diff) > 50) {
    if (diff > 0) {
      moveSlide(1); // Swipe left
    } else {
      moveSlide(-1); // Swipe right
    }
  }
});



