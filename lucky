// PYTHON SCRIPT GENERATOR
// ══════════════════════════════════════════════
function generatePythonScript() {
  const allFiles = getAllFiles();
  const filesList = allFiles.map(f =>
    `    (${JSON.stringify(f.path)}, ${JSON.stringify(f.content)}),`
  ).join('\n');

  return `#!/usr/bin/env python3
"""
GHOST PROTOCOL: INFINITE ADAPTATION
FLM Deployer — ADEN131313/sovereign-core
All 12 agents · Every file · 1-second updater

INSTRUCTIONS:
  1. Revoke old token at github.com/settings/tokens
  2. Generate new token (repo scope)
  3. pip install aiohttp
  4. export GITHUB_TOKEN=your_NEW_token
  5. python deploy.py
"""
import os, sys, base64, json, time, asyncio
import aiohttp

# ── CONFIG ────────────────────────────────────────────
GITHUB_TOKEN = os.environ.get("GITHUB_TOKEN", "YOUR_NEW_TOKEN_HERE")
REPO_OWNER   = "ADEN131313"
REPO_NAME    = "sovereign-core"
BRANCH       = "main"
BASE_URL     = f"https://api.github.com/repos/{REPO_OWNER}/{REPO_NAME}"
HEADERS = {
    "Authorization":        f"Bearer {GITHUB_TOKEN}",
    "Accept":               "application/vnd.github+json",
    "X-GitHub-Api-Version": "2022-11-28",
}

sha_cache: dict[str, str] = {}

# ── ALL FILES ─────────────────────────────────────────
FILES = [
${filesList}
]

# ── GITHUB API ────────────────────────────────────────
async def get_sha(session: aiohttp.ClientSession, path: str) -> str | None:
    if path in sha_cache:
        return sha_cache[path]
    async with session.get(
        f"{BASE_URL}/contents/{path}?ref={BRANCH}",
        headers=HEADERS
    ) as r:
        if r.status == 200:
            d = await r.json()
            sha_cache[path] = d.get("sha", "")
            return sha_cache[path]
    return None

async def push_file(
    session: aiohttp.ClientSession,
    path: str, content: str, msg: str
) -> bool:
    sha     = await get_sha(session, path)
    encoded = base64.b64encode(content.encode("utf-8")).decode()
    payload: dict = {
        "message": msg,
        "content": encoded,
        "branch":  BRANCH,
    }
    if sha:
        payload["sha"] = sha
    async with session.put(
        f"{BASE_URL}/contents/{path}",
        headers=HEADERS,
        json=payload
    ) as r:
        if r.status in (200, 201):
            d       = await r.json()
            new_sha = d.get("content", {}).get("sha")
            if new_sha:
                sha_cache[path] = new_sha
            return True
        text = await r.text()
        print(f"  ❌ HTTP {r.status}: {text[:80]}")
        return False

# ── DEPLOY ALL ────────────────────────────────────────
async def deploy_all() -> None:
    print("\\n" + "═" * 62)
    print("  GHOST PROTOCOL: INFINITE ADAPTATION")
    print(f"  Repo: {REPO_OWNER}/{REPO_NAME}")
    print(f"  Files: {len(FILES)}")
    print("═" * 62)

    if GITHUB_TOKEN == "YOUR_NEW_TOKEN_HERE":
        print("\\n❌ ERROR: Set GITHUB_TOKEN environment variable:")
        print("   export GITHUB_TOKEN=ghp_your_new_token_here")
        sys.exit(1)

    done = 0
    start = time.monotonic()

    async with aiohttp.ClientSession() as session:
        for i, (path, content) in enumerate(FILES, 1):
            pct = int(i / len(FILES) * 100)
            print(f"  [{i:03d}/{len(FILES)}] {path}", end=" ", flush=True)
            ok = await push_file(
                session, path, content,
                f"feat: {path.split('/')[-1]} [Ghost Protocol FLM]"
            )
            print("✅" if ok else "❌")
            if ok:
                done += 1
            await asyncio.sleep(0.3)  # Avoid rate limit

    elapsed = time.monotonic() - start
    print("\\n" + "═" * 62)
    print(f"  ✅ {done}/{len(FILES)} files deployed")
    print(f"  ✅ Time: {elapsed:.1f}s")
    print(f"  ✅ github.com/{REPO_OWNER}/{REPO_NAME}")
    print("═" * 62)

# ── 1-SECOND LIVE UPDATER ─────────────────────────────
async def live_updater() -> None:
    """
    After initial deploy — keeps all FLMs updated every second.
    Commits cycle logs for all 12 agents continuously.
    """
    import hashlib
    agents = [
        "ghost","lucky","oracle","nexus","cipher","wraith",
        "sage","titan","vex","echo","axiom","sovereign"
    ]
    cycle = 0
    print("\\n⚡ LIVE UPDATER STARTED — 1 second cycle")
    print("   Press Ctrl+C to stop")
    async with aiohttp.ClientSession() as session:
        while True:
            t0  = time.monotonic()
            agent = agents[cycle % len(agents)]
            ts  = __import__("datetime").datetime.utcnow().isoformat()
            content = json.dumps({
                "flm_id":      f"{agent.upper()}-FLM-∞-356O",
                "agent":       agent,
                "cycle":       cycle,
                "last_update": ts,
                "status":      "running",
                "true_north":  {"ceiling": None, "immutable": True}
            }, indent=2)
            path = f"agents/{agent}/state/cycle_log.json"
            ok   = await push_file(
                session, path, content,
                f"[{agent.upper()}-FLM-∞] adopt-implant cycle {cycle:06d}"
            )
            elapsed = (time.monotonic() - t0) * 1000
            status  = "✅" if ok else "❌"
            print(f"  {status} [{agent.upper()}-FLM-∞] cycle {cycle:06d} · {elapsed:.0f}ms")
            cycle += 1
            sleep = max(0, 1.0 - (time.monotonic() - t0))
            await asyncio.sleep(sleep)

if __name__ == "__main__":
    import argparse
    p = argparse.ArgumentParser(description="Ghost Protocol FLM Deployer")
    p.add_argument("--update", action="store_true", help="Run live updater after deploy")
    args = p.parse_args()

    async def main():
        await deploy_all()
        if args.update:
            await live_updater()

    asyncio.run(main())
`;
}

