async function startDeploy() {
  // Get token from form if not set
  const inp = document.getElementById('token-inp');
  if(inp?.value?.trim()) deployToken = inp.value.trim();
  const ri  = document.getElementById('repo-inp');
  if(ri?.value?.trim()) deployRepo   = ri.value.trim();
  const bi  = document.getElementById('branch-inp');
  if(bi?.value?.trim()) deployBranch = bi.value.trim();

  if(!deployToken) {
    go('setup');
    alert('Enter your new GitHub token in the Setup tab first.');
    return;
  }
  if(deployActive) return;

  deployActive = true;
  shaCache     = {};
  doneFiles    = 0;
  startTime    = Date.now();

  const allFiles = getAllFiles();
  totalFiles     = allFiles.length;

  // Make sure we're on deploy tab
  go('deploy');

  // UI
  const startBtn = document.getElementById('start-btn');
  if(startBtn) { startBtn.disabled = true; startBtn.textContent = '⚡ Deploying...'; }
  document.getElementById('console-badge').textContent = 'Deploying...';
  document.getElementById('console-badge').className   = 'chip ch-q';

  cLog('q', '════════ GHOST PROTOCOL: INFINITE ADAPTATION ════════');
  cLog('info', `Repo: ${deployRepo} · Branch: ${deployBranch}`);
  cLog('info', `Total files: ${totalFiles} · Agents: 12`);
  cLog('q', '═════════════════════════════════════════════════════');

  // Deploy root files first
  cLog('info', '📄 Deploying root files...');
  for(const f of ROOT_FILES) {
    updateGP(doneFiles, totalFiles, f.path);
    cLog('info', `  → ${f.path}`);
    const result = await pushFile(
      deployToken, deployRepo, deployBranch,
      f.path, f.content,
      `feat: add ${f.path.split('/').pop()} [Ghost Protocol FLM]`
    );
    if(result.ok) {
      doneFiles++;
      cLog('ok', `  ✅ ${f.path}`);
    } else {
      cLog('err', `  ❌ ${f.path}: ${result.error}`);
      if(result.error?.includes('CORS') || result.error?.includes('fetch')) {
        cLog('warn', '  ⚠️ Browser CORS detected — use Python script tab');
        deployActive = false;
        if(startBtn) { startBtn.disabled = false; startBtn.textContent = '⚡ START DEPLOYMENT'; }
        go('python');
        return;
      }
    }
    updateGP(doneFiles, totalFiles, f.path);
    await sleep(300);
  }

  // Deploy each agent
  for(const a of AGENTS) {
    cLog('info', `\n${a.e} Deploying ${a.n} — ${a.flm}...`);
    updateAgentCard(a.id, -1, 'deploying', 0);
    const files = buildAgentFiles(a);

    for(let i = 0; i < files.length; i++) {
      const f = files[i];
      updateAgentCard(a.id, i, 'deploying', Math.round(i/files.length*100));
      updateGP(doneFiles, totalFiles, f.path);
      cLog('info', `  → ${f.path}`);

      const result = await pushFile(
        deployToken, deployRepo, deployBranch,
        f.path, f.content,
        `feat(${a.id}): ${f.path.split('/').pop()} [${a.flm}]`
      );

      if(result.ok) {
        doneFiles++;
        updateAgentCard(a.id, i, 'done', Math.round((i+1)/files.length*100));
        cLog('ok', `  ✅ ${f.path.split('/').pop()}`);
      } else {
        updateAgentCard(a.id, i, 'error', Math.round(i/files.length*100));
        cLog('err', `  ❌ ${f.path.split('/').pop()}: ${result.error}`);
      }
      updateGP(doneFiles, totalFiles, f.path);
      await sleep(250);
    }

    updateAgentCard(a.id, -1, 'done', 100);
    cLog('ok', `  ${a.e} ${a.n} — all files deployed`);
  }

  // Done
  deployActive = false;
  const elapsed = Math.round((Date.now() - startTime) / 1000);
  cLog('q', '\n════════ DEPLOYMENT COMPLETE ════════');
  cLog('ok', `✅ ${doneFiles} files created`);
  cLog('ok', `✅ 12 agents deployed`);
  cLog('ok', `✅ 12 CI workflows active`);
  cLog('ok', `✅ Time: ${elapsed}s`);
  cLog('ok', `✅ github.com/${deployRepo}`);
  updateGP(totalFiles, totalFiles, '✅ All files deployed');

  if(startBtn) { startBtn.disabled = false; startBtn.textContent = '✅ Deploy Again'; }
  document.getElementById('console-badge').textContent = 'Complete ✅';
  document.getElementById('console-badge').className   = 'chip ch-g';
  document.getElementById('deploy-all-btn').textContent = '✅ Deployed';

  const sum = document.getElementById('summary-card');
  if(sum) {
    sum.style.display = 'block';
    sum.querySelector('#summary-stats').innerHTML = [
      {l:'Files',v:doneFiles,c:'var(--g)'},{l:'Agents',v:12,c:'var(--b)'},
      {l:'CI Workflows',v:13,c:'var(--p)'},{l:'Time',v:elapsed+'s',c:'var(--y)'},
    ].map(s=>`<div style="text-align:center;padding:8px;background:rgba(0,255,136,.04);border-radius:7px"><div style="font-size:18px;font-weight:700;color:${s.c}">${s.v}</div><div style="font-size:8px;color:rgba(0,255,136,.4);margin-top:2px">${s.l}</div></div>`).join('');
  }
}

