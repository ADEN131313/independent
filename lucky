(function() {
  const c = document.getElementById('mbg');
  if(!c) return;
  const ctx = c.getContext('2d');
  c.width = innerWidth; c.height = innerHeight;
  addEventListener('resize', () => { c.width = innerWidth; c.height = innerHeight; });
  const cols = Math.floor(c.width / 14);
  const drops = Array(cols).fill(0);
  const chars = '01ABCDEF01₿Ξ⚛01';
  setInterval(() => {
    ctx.fillStyle = 'rgba(0,0,0,.05)'; ctx.fillRect(0,0,c.width,c.height);
    ctx.fillStyle = '#00ff88'; ctx.font = '12px JetBrains Mono';
    drops.forEach((y, i) => {
      ctx.fillText(chars[Math.random()*chars.length|0], i*14, y*14);
      if(y*14 > c.height && Math.random() > .975) drops[i] = 0;
      else drops[i]++;
    });
  }, 60);
})();

setInterval(() => {
  ['console-cursor','upd-cursor'].forEach(id => {
    const c = document.getElementById(id);
    if(c) c.textContent = c.textContent === '█' ? '' : ' █';
  });
}, 600);

function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }
