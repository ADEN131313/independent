  navigator.clipboard.writeText(generatePythonScript()).then(() => {
    alert('✅ Python script copied!\n\nNow:\n1. Revoke old token\n2. Generate new token\n3. pip install aiohttp\n4. export GITHUB_TOKEN=your_new_token\n5. python deploy.py');
  }).catch(() => {
    alert('Could not copy. Use the Download button instead.');
  });
}

function downloadPython() {
  const blob = new Blob([generatePythonScript()], { type: 'text/plain' });
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href     = url;
  a.download = 'deploy.py';
  a.click();
  URL.revokeObjectURL(url);
}

