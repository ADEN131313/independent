# Deployment Configuration
# Copy this to .env.deploy and customize for your environment

# === GITHUB DEPLOYMENT ===
GITHUB_REPO=your-username/sovereign-multiagent-system
GITHUB_TOKEN=your_github_personal_access_token

# === VERCEL DEPLOYMENT (Frontend) ===
VERCEL_TOKEN=your_vercel_token
VERCEL_ORG_ID=your_vercel_org_id
VERCEL_PROJECT_NAME=sovereign-task-manager-frontend

# === RAILWAY DEPLOYMENT (Backend) ===
RAILWAY_TOKEN=your_railway_token
RAILWAY_PROJECT_NAME=sovereign-task-manager-backend

# === RENDER DEPLOYMENT (Multi-Agent System) ===
RENDER_API_KEY=your_render_api_key
RENDER_SERVICE_NAME=multi-agent-system

# === DATABASE CONFIGURATION ===
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/sovereign-tasks
REDIS_URL=redis://username:password@your-redis-instance:6379

# === AI MODEL CONFIGURATION ===
MODEL_NAME=microsoft/DialoGPT-medium
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
DEVICE=cpu  # or cuda for GPU

# === SECURITY ===
JWT_SECRET=your-super-secure-jwt-secret-key
JWT_REFRESH_SECRET=your-refresh-token-secret
ENCRYPTION_KEY=your-32-character-encryption-key

# === MONITORING ===
SENTRY_DSN=your_sentry_dsn_for_error_tracking
LOG_LEVEL=INFO